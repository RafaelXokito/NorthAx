# Server
PORT=8080
ENV=development
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql+asyncpg://northax:northax@localhost:5432/northax

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT (RS256). Generate keys with:
#   openssl genrsa -out jwt_private.pem 2048
#   openssl rsa -in jwt_private.pem -pubout -out jwt_public.pem
# Then base64-encode each PEM (no line wraps):
#   base64 -i jwt_private.pem | tr -d '\n'
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=60

# Sign in with Apple
APPLE_CLIENT_ID=app.northax.client
APPLE_JWKS_URL=https://appleid.apple.com/auth/keys
APPLE_ISSUER=https://appleid.apple.com

# AI transport — the AI layer shells out to the Hermes agent CLI (`hermes -z`),
# so no API key is needed; just an authenticated `hermes` on PATH (`hermes login`).
HERMES_CLI_PATH=hermes
HERMES_PROVIDER=
# Recommended: --ignore-rules keeps AGENTS.md/SOUL.md/memory out of prompts.
HERMES_EXTRA_ARGS=
# Model overrides (Hermes "provider/model" strings). Empty → Hermes default.
AI_MODEL_FAST=
AI_MODEL_DEFAULT=
AI_CLI_FAST_TIMEOUT=60
AI_CLI_DEFAULT_TIMEOUT=90
# Only needed if you swap the AI layer back to the Anthropic SDK (extra: api)
ANTHROPIC_API_KEY=

# intervals.icu (OAuth 2.0) — man-in-the-middle aggregator over Garmin/Strava.
# Register an OAuth app at intervals.icu (Settings → Developer) for these.
INTERVALS_CLIENT_ID=
INTERVALS_CLIENT_SECRET=
INTERVALS_REDIRECT_URI=https://api.northax.app/v1/intervals/callback
INTERVALS_OAUTH_AUTHORIZE_URL=https://intervals.icu/oauth/authorize
INTERVALS_OAUTH_TOKEN_URL=https://intervals.icu/api/oauth/token
INTERVALS_API_BASE=https://intervals.icu/api/v1
INTERVALS_SCOPES=WELLNESS:READ,ACTIVITY:READ,CALENDAR:WRITE

# AES-256-GCM key for encrypting intervals.icu tokens at rest (32-byte hex string)
#   openssl rand -hex 32
ENCRYPTION_KEY=

# App deep link
APP_SCHEME=northax://

# Optional
SENTRY_DSN=
