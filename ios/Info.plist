<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- App Transport Security: allow plain-HTTP to the Raspberry Pi backend on
	     the local network (private-IP literals + .local). Other Info.plist keys
	     are still produced by GENERATE_INFOPLIST_FILE and merged in at build. -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
</dict>
</plist>
